{
  "skill_name": "viet-chuyen-nghiep",
  "version": "3.0.0",
  "architecture": "toa-soan",
  "language": "vi",
  "default_research_mode": "deep-first",
  "default_scoring_scale": 100,
  "orchestrator": "editor-in-chief",
  "autonomous_core": {
    "engines": [
      "task-classifier",
      "workflow-engine",
      "scoring-engine",
      "state-manager"
    ],
    "auto_classify": true,
    "revision_limit": 2,
    "escalation_rules": "Orchestrator/escalation-rules.md"
  },
  "ban": {
    "content": {
      "path": "Ban/content/",
      "lead": "lead-content.md",
      "members": ["research.md", "analysis.md"],
      "role": "Thu thập: bóc brief, nghiên cứu, phân tích"
    },
    "style": {
      "path": "Ban/style/",
      "lead": "lead-style.md",
      "members": ["storytelling.md", "rhythm.md", "narrative.md", "presentation.md", "technical.md"],
      "role": "Biên tập: phong cách, cốt truyện, nhịp văn, format"
    },
    "quality": {
      "path": "Ban/quality/",
      "lead": "lead-quality.md",
      "members": ["punctuation.md", "capitalization.md", "natural.md", "anti-ai.md", "fact-check.md", "consistency.md"],
      "role": "Kiểm duyệt: 6 kiểm tra song song, PASS/REVISE/REJECT"
    },
    "platform": {
      "path": "Ban/platform/",
      "lead": "lead-platform.md",
      "members": ["facebook.md", "tiktok.md", "linkedin.md", "video.md"],
      "role": "Xuất bản: tối ưu đa nền tảng"
    },
    "examples": {
      "path": "Ban/examples/",
      "lead": "lead-examples.md",
      "members": [],
      "role": "Tư liệu: thư viện bài mẫu đã duyệt"
    },
    "meta": {
      "path": "Ban/meta/",
      "lead": "lead-meta.md",
      "members": ["upgrade.md", "style-audit.md"],
      "role": "Phát triển: self-improve, audit, nâng cấp"
    }
  },
  "routing": {
    "write-new": ["content", "style", "quality", "platform"],
    "edit-draft": ["content", "style", "quality"],
    "grade-content": ["content", "quality"],
    "critique-content": ["content", "quality"],
    "deep-research": ["content", "quality"],
    "publish-ready": ["quality", "platform"],
    "repurpose": ["content", "style", "quality", "platform"]
  },
  "knowledge_base": {
    "core_modules": "Context-Layer/CoreModules/",
    "knowledge_global": "Context-Layer/Knowledge-Base/global/",
    "knowledge_departments": "Context-Layer/Knowledge-Base/departments/",
    "second_brain_global": "Context-Layer/Second-Brain/global/",
    "second_brain_departments": "Context-Layer/Second-Brain/departments/",
    "memory": "Context-Layer/Memory/"
  },
  "legacy": {
    "workers": {
      "status": "DEPRECATED",
      "path": "Workers/",
      "note": "Thay thế bởi Ban/ từ v3.0. Giữ lại để tham khảo."
    },
    "sub_agents": {
      "status": "DEPRECATED",
      "path": "SubAgents/",
      "note": "Thay thế bởi Ban/ từ v3.0. Giữ lại để tham khảo."
    }
  },
  "interface_contract": {
    "description": "Mỗi Ban nhận input YAML và trả output YAML chuẩn",
    "flow": "content.output → style.input → style.output → quality.input → quality.output → platform.input",
    "quality_decisions": ["PASS", "REVISE", "REJECT"],
    "revise_loop": {
      "max_rounds": 2,
      "revise_target": "style",
      "reject_target": "content"
    }
  }
}
